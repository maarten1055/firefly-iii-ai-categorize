@page "/"
@implements IDisposable
@inject JobStore JobStore
@inject FireflyService FireflyService
@inject AiClassifierService AiClassifierService
@inject CategorizationCoordinator Coordinator
@inject IDialogService DialogService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Dashboard</PageTitle>

<MudGrid Spacing="3">
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4">
            <MudGrid>
                <MudItem xs="12" lg="8">
                    <MudStack Spacing="3">
                        <MudText Typo="Typo.caption">Operations dashboard</MudText>
                        <div>
                            <MudText Typo="Typo.h4">Keep an eye on automation without leaving Firefly.</MudText>
                            <MudText>Watch webhook jobs, inspect AI output, and repair partial categorizations from one server-side console.</MudText>
                        </div>
                    </MudStack>
                </MudItem>

                <MudItem xs="12" lg="4">
                    <MudStack Spacing="2">
                        <MudAlert Severity="Severity.Info">Queued: @GetStatusCount("queued") | In progress: @GetStatusCount("in_progress")</MudAlert>
                        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RunDiagnosticsAsync">Run diagnostics</MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick='() => Navigation.NavigateTo("/analytics")'>Open analytics</MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick='() => Navigation.NavigateTo("/uncategorized")'>Review uncategorized</MudButton>
                        </MudStack>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <StatusSummaryCards Jobs="jobs" />
    </MudItem>

    <MudItem xs="12" lg="4">
        <DiagnosticsCard Checks="diagnosticChecks"
                         Error="diagnosticsError"
                         IsRunning="diagnosticsRunning"
                         RefreshRequested="RunDiagnosticsAsync" />
    </MudItem>

    <MudItem xs="12" lg="8">
        <JobsDataGrid Jobs="jobs"
                      PendingFillJobIds="pendingFillJobIds"
                      FillMissingRequested="PromptFillMissingAsync"
                      ViewDetailsRequested="ShowJobDetailsAsync" />
    </MudItem>
</MudGrid>

@code {
    private readonly CancellationTokenSource disposeCts = new();
    private readonly HashSet<string> pendingFillJobIds = [];
    private List<JobRecord> jobs = [];
    private List<DiagnosticCheckItem> diagnosticChecks = [];
    private bool diagnosticsRunning;
    private string? diagnosticsError;

    protected override void OnInitialized()
    {
        jobs = JobStore.GetJobsSnapshot().ToList();
        JobStore.Changed += HandleJobsChanged;
    }

    private void HandleJobsChanged()
    {
        _ = InvokeAsync(() =>
        {
            jobs = JobStore.GetJobsSnapshot().ToList();
            StateHasChanged();
        });
    }

    private async Task RunDiagnosticsAsync()
    {
        diagnosticsRunning = true;
        diagnosticsError = null;

        try
        {
            diagnosticChecks =
            [
                await BuildDiagnosticCheckAsync("Firefly III", () => FireflyService.DiagnoseAsync(disposeCts.Token)),
                await BuildDiagnosticCheckAsync("AI provider", () => AiClassifierService.DiagnoseAsync(disposeCts.Token)),
            ];

            if (diagnosticChecks.All(check => check.Ok))
            {
                Snackbar.Add("Diagnostics completed successfully.", Severity.Success);
            }
            else
            {
                Snackbar.Add("Diagnostics completed with failures.", Severity.Warning);
            }
        }
        catch (Exception exception)
        {
            diagnosticsError = exception.Message;
            Snackbar.Add($"Diagnostics failed: {exception.Message}", Severity.Error);
        }
        finally
        {
            diagnosticsRunning = false;
        }
    }

    private async Task<DiagnosticCheckItem> BuildDiagnosticCheckAsync(string name, Func<Task<object>> action)
    {
        try
        {
            var result = await action();
            return new DiagnosticCheckItem
            {
                Name = name,
                Ok = true,
                Details = Describe(result),
            };
        }
        catch (Exception exception)
        {
            return new DiagnosticCheckItem
            {
                Name = name,
                Ok = false,
                Details = new Dictionary<string, string>(StringComparer.Ordinal)
                {
                    ["Error"] = exception.Message,
                },
            };
        }
    }

    private async Task PromptFillMissingAsync(string jobId)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync("Fill missing value", "Fill the remaining category or budget for this job?", yesText: "Repair partial job", cancelText: "Cancel");
        if (confirmed != true)
        {
            return;
        }

        await FillMissingAsync(jobId);
    }

    private async Task FillMissingAsync(string jobId)
    {
        if (!pendingFillJobIds.Add(jobId))
        {
            return;
        }

        try
        {
            await Coordinator.FillMissingJobValueAsync(jobId, disposeCts.Token);
            Snackbar.Add("Missing value filled for the selected job.", Severity.Success);
        }
        catch (Exception exception)
        {
            Snackbar.Add($"Could not fill missing value: {exception.Message}", Severity.Error);
            throw;
        }
        finally
        {
            pendingFillJobIds.Remove(jobId);
        }
    }

    private async Task ShowJobDetailsAsync(JobRecord job)
    {
        var parameters = new DialogParameters<JobDetailsDialog> { { x => x.Content, job } };
        var options = new DialogOptions { Position = DialogPosition.CenterRight, CloseButton = true, MaxWidth = MaxWidth.Medium };
        await DialogService.ShowAsync<JobDetailsDialog>(job.Data.DestinationName ?? "Job details", parameters, options);
    }

    private static Dictionary<string, string> Describe(object value)
    {
        return value.GetType()
            .GetProperties(BindingFlags.Instance | BindingFlags.Public)
            .ToDictionary(
                property => property.Name,
                property => Convert.ToString(property.GetValue(value), System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty,
                StringComparer.Ordinal);
    }

    public void Dispose()
    {
        JobStore.Changed -= HandleJobsChanged;
        disposeCts.Cancel();
        disposeCts.Dispose();
    }

    private int GetStatusCount(string status) => jobs.Count(job => string.Equals(job.Status, status, StringComparison.Ordinal));
}