@page "/uncategorized"
@implements IAsyncDisposable
@inject FireflyService FireflyService
@inject CategorizationCoordinator Coordinator
@inject ILogger<Uncategorized> Logger
@inject IDialogService DialogService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Uncategorized Transactions</PageTitle>

<MudGrid Spacing="3">
    <MudItem xs="12">
        <MudPaper Class="pa-4">
            <MudGrid>
                <MudItem xs="12" lg="8">
                    <MudStack Spacing="3">
                        <MudText Typo="Typo.caption">Review workspace</MudText>
                        <div>
                            <MudText Typo="Typo.h4">Transactions missing category or budget</MudText>
                            <MudText>Filter by destination, classify individual items, or apply one decision across a destination batch.</MudText>
                        </div>
                    </MudStack>
                </MudItem>

                <MudItem xs="12" lg="4">
                    <MudStack Spacing="2">
                        <MudAlert Severity="Severity.Info">Destination: @(string.IsNullOrWhiteSpace(selectedDestination) ? "All" : selectedDestination)</MudAlert>
                        <MudAlert Severity="@(paginationComplete ? Severity.Success : Severity.Info)">Page @(page) of @(paginationComplete ? totalPages.ToString() : $"{totalPages}+")</MudAlert>
                        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick='() => Navigation.NavigateTo("/")'>Back to dashboard</MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RefreshAllAsync">Refresh</MudButton>
                        </MudStack>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>

    @if (!string.IsNullOrWhiteSpace(pageError))
    {
        <MudItem xs="12">
            <MudAlert Severity="Severity.Error" Title="Load failed">@pageError</MudAlert>
        </MudItem>
    }

    @if (!string.IsNullOrWhiteSpace(pageSuccess))
    {
        <MudItem xs="12">
            <MudAlert Severity="Severity.Success" Title="Update complete">@pageSuccess</MudAlert>
        </MudItem>
    }

    <MudItem xs="12">
        <UncategorizedSummaryCards Summary="summary"
                                   MetadataComplete="metadataComplete"
                                   PaginationComplete="paginationComplete" />
    </MudItem>

    <MudItem xs="12" lg="6">
        <UncategorizedFiltersCard Page="page"
                                  PageSize="pageSize"
                                  PageSizeOptions="pageSizeOptions"
                                  SelectedDestination="selectedDestination"
                                  Destinations="destinations"
                                  PaginationComplete="paginationComplete"
                                  TotalPages="totalPages"
                                  PageSizeChanged="OnPageSizeChanged"
                                  DestinationChanged="OnDestinationChanged" />
    </MudItem>

    <MudItem xs="12" lg="6">
        <BulkUpdateCard SelectedDestination="selectedDestination"
                        Categories="categories"
                        Budgets="budgets"
                        BulkCategory="bulkCategory"
                        BulkBudget="bulkBudget"
                        CanApply="CanBulkApply"
                        IsPending="bulkApplyPending"
                        BulkCategoryChanged="OnBulkCategoryChanged"
                        BulkBudgetChanged="OnBulkBudgetChanged"
                        ApplyRequested="PromptBulkApplyAsync" />
    </MudItem>

    <MudItem xs="12">
        <MudPaper Class="pa-4">
            <MudStack Spacing="3">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <div>
                        <MudText Typo="Typo.caption">Current page</MudText>
                        <MudText Typo="Typo.h5">Transactions</MudText>
                    </div>
                    <MudText><strong>@items.Count row(s)</strong></MudText>
                </MudStack>

                @if (items.Count == 0 && string.IsNullOrWhiteSpace(pageError))
                {
                    <MudText>No transactions match the current filter.</MudText>
                }
                else
                {
                    <MudTable Items="items" Hover="true" Dense="true">
                        <HeaderContent>
                            <MudTh>Destination</MudTh>
                            <MudTh>Description</MudTh>
                            <MudTh>Amount</MudTh>
                            <MudTh>Category</MudTh>
                            <MudTh>Budget</MudTh>
                            <MudTh>Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Destination">
                                <MudStack Spacing="1">
                                    <strong>@GetDisplay(context.DestinationName, "Unknown destination")</strong>
                                    <MudText Typo="Typo.caption">@GetDisplay(context.Date, "No date")</MudText>
                                </MudStack>
                            </MudTd>
                            <MudTd DataLabel="Description">
                                <MudStack Spacing="1">
                                    <strong>@GetDisplay(context.Description, "No description")</strong>
                                    <MudText Typo="Typo.caption">@GetDisplay(context.SourceName, "Unknown source")</MudText>
                                </MudStack>
                            </MudTd>
                            <MudTd DataLabel="Amount">
                                <MudStack Spacing="1">
                                    <strong>@FormatAmount(context)</strong>
                                    <MudText Typo="Typo.caption">@GetTransactionStatus(context)</MudText>
                                </MudStack>
                            </MudTd>
                            <MudTd DataLabel="Category">
                                @{ var selection = GetSelection(context.TransactionJournalId); }
                                @if (!string.IsNullOrWhiteSpace(context.Category))
                                {
                                    <strong>@context.Category</strong>
                                }
                                else
                                {
                                    <MudSelect T="string" Dense="true" Margin="Margin.Dense"
                                               Value="@(selection.Category ?? string.Empty)"
                                               ValueChanged="value => OnCategorySelectionChanged(context.TransactionJournalId, value)">
                                        <MudSelectItem T="string" Value="@string.Empty">Select category</MudSelectItem>
                                        @foreach (var category in categories)
                                        {
                                            <MudSelectItem T="string" Value="@category">@category</MudSelectItem>
                                        }
                                    </MudSelect>
                                    @if (!string.IsNullOrWhiteSpace(GetClassification(context.TransactionJournalId)?.Category))
                                    {
                                        <MudText Typo="Typo.caption">AI: @GetClassification(context.TransactionJournalId)?.Category</MudText>
                                    }
                                }
                            </MudTd>
                            <MudTd DataLabel="Budget">
                                @{ var selection = GetSelection(context.TransactionJournalId); }
                                @if (!string.IsNullOrWhiteSpace(context.Budget))
                                {
                                    <strong>@context.Budget</strong>
                                }
                                else
                                {
                                    <MudSelect T="string" Dense="true" Margin="Margin.Dense"
                                               Value="@(selection.Budget ?? string.Empty)"
                                               ValueChanged="value => OnBudgetSelectionChanged(context.TransactionJournalId, value)">
                                        <MudSelectItem T="string" Value="@string.Empty">Select budget</MudSelectItem>
                                        @foreach (var budget in budgets)
                                        {
                                            <MudSelectItem T="string" Value="@budget">@budget</MudSelectItem>
                                        }
                                    </MudSelect>
                                    @if (!string.IsNullOrWhiteSpace(GetClassification(context.TransactionJournalId)?.Budget))
                                    {
                                        <MudText Typo="Typo.caption">AI: @GetClassification(context.TransactionJournalId)?.Budget</MudText>
                                    }
                                }
                            </MudTd>
                            <MudTd DataLabel="Actions">
                                <MudStack Spacing="1">
                                    <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                                        <MudButton Variant="Variant.Text" Size="Size.Small"
                                                   Disabled="@pendingClassifications.Contains(context.TransactionJournalId)"
                                                   OnClick="() => ClassifyAsync(context)">
                                            @(pendingClassifications.Contains(context.TransactionJournalId) ? "Classifying..." : "Ask AI")
                                        </MudButton>
                                        <MudButton Variant="Variant.Text" Size="Size.Small"
                                                   Disabled="@(GetClassification(context.TransactionJournalId) is null)"
                                                   OnClick="() => ShowTransactionDetailsAsync(context)">
                                            Details
                                        </MudButton>
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                                   Disabled="@(!CanApply(context) || pendingUpdates.Contains(context.TransactionJournalId))"
                                                   OnClick="() => ApplyAsync(context)">
                                            @(pendingUpdates.Contains(context.TransactionJournalId) ? "Applying..." : "Apply")
                                        </MudButton>
                                    </MudStack>
                                    @if (!string.IsNullOrWhiteSpace(GetClassification(context.TransactionJournalId)?.Error))
                                    {
                                        <MudAlert Severity="Severity.Error" Dense="true">@GetClassification(context.TransactionJournalId)?.Error</MudAlert>
                                    }
                                </MudStack>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12">
        <MudPaper Class="pa-3">
            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                <MudButton Variant="Variant.Text" Disabled="@(page <= 1)" OnClick="PreviousPageAsync">Previous</MudButton>
                @foreach (var number in GetVisiblePages())
                {
                    <MudButton Variant="@(number == page ? Variant.Filled : Variant.Text)"
                               Color="@(number == page ? Color.Primary : Color.Default)"
                               OnClick="() => GoToPageAsync(number)">
                        @number
                    </MudButton>
                }
                <MudButton Variant="Variant.Text" Disabled="@(!CanMoveNext)" OnClick="NextPageAsync">Next</MudButton>
            </MudStack>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private readonly CancellationTokenSource disposeCts = new();
    private readonly int[] pageSizeOptions = [10, 20, 50];
    private readonly HashSet<string> pendingClassifications = [];
    private readonly HashSet<string> pendingUpdates = [];
    private readonly Dictionary<string, ClassificationResult> classifications = new(StringComparer.Ordinal);
    private readonly Dictionary<string, SelectionValues> selections = new(StringComparer.Ordinal);

    private List<UncategorizedTransaction> items = [];
    private List<string> categories = [];
    private List<string> budgets = [];
    private List<string> destinations = [];
    private MetadataSummary summary = new();
    private string selectedDestination = string.Empty;
    private string bulkCategory = string.Empty;
    private string bulkBudget = string.Empty;
    private string? pageError;
    private string? pageSuccess;
    private int page = 1;
    private int pageSize = 20;
    private int totalPages = 1;
    private bool paginationComplete;
    private bool metadataComplete;
    private bool bulkApplyPending;
    private PeriodicTimer? refreshTimer;
    private Task? refreshLoopTask;
    private bool loadingMetadata;
    private bool loadingTransactions;

    private bool CanBulkApply => !string.IsNullOrWhiteSpace(selectedDestination) && (!string.IsNullOrWhiteSpace(bulkCategory) || !string.IsNullOrWhiteSpace(bulkBudget));
    private bool CanMoveNext => page < totalPages || !paginationComplete;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAllAsync();

        if (string.IsNullOrWhiteSpace(pageError))
        {
            refreshTimer = new PeriodicTimer(TimeSpan.FromSeconds(2));
            refreshLoopTask = RunRefreshLoopAsync();
        }
    }

    private async Task RunRefreshLoopAsync()
    {
        try
        {
            while (refreshTimer is not null && await refreshTimer.WaitForNextTickAsync(disposeCts.Token))
            {
                if (metadataComplete && paginationComplete)
                {
                    continue;
                }

                await InvokeAsync(async () =>
                {
                    try
                    {
                        await LoadMetadataAsync();
                        if (!paginationComplete)
                        {
                            await LoadTransactionsAsync();
                        }
                    }
                    catch (Exception exception)
                    {
                        Logger.LogDebug(exception, "Background refresh failed.");
                    }

                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task LoadOptionsAsync()
    {
        categories = (await FireflyService.GetCategoriesAsync(disposeCts.Token)).Keys.OrderBy(value => value, StringComparer.Ordinal).ToList();
        budgets = (await FireflyService.GetBudgetsAsync(disposeCts.Token)).Keys.OrderBy(value => value, StringComparer.Ordinal).ToList();
    }

    private async Task RefreshAllAsync()
    {
        pageError = null;
        pageSuccess = null;

        try
        {
            await LoadOptionsAsync();
            await LoadMetadataAsync();
            await LoadTransactionsAsync();
            Snackbar.Add("Transaction data refreshed.", Severity.Success);
        }
        catch (Exception exception)
        {
            pageError = exception.Message;
            Logger.LogWarning(exception, "Could not load uncategorized transactions page.");
        }
    }

    private async Task LoadMetadataAsync()
    {
        if (loadingMetadata)
        {
            return;
        }

        loadingMetadata = true;
        try
        {
            var result = await FireflyService.GetUncategorizedMetadataAsync(ToNullable(selectedDestination), disposeCts.Token);
            summary = result.Summary;
            destinations = result.Destinations;
            metadataComplete = result.Complete;

            if (!string.IsNullOrWhiteSpace(selectedDestination) && !destinations.Contains(selectedDestination, StringComparer.Ordinal))
            {
                selectedDestination = string.Empty;
                page = 1;
            }
        }
        finally
        {
            loadingMetadata = false;
        }
    }

    private async Task LoadTransactionsAsync()
    {
        if (loadingTransactions)
        {
            return;
        }

        loadingTransactions = true;
        try
        {
            var result = await FireflyService.GetUncategorizedTransactionsAsync(page, pageSize, ToNullable(selectedDestination), disposeCts.Token);
            items = result.Items;
            totalPages = Math.Max(1, result.TotalPages);
            paginationComplete = result.Complete;

            foreach (var transaction in items)
            {
                _ = GetSelection(transaction.TransactionJournalId);
            }
        }
        catch (Exception exception)
        {
            pageError = exception.Message;
        }
        finally
        {
            loadingTransactions = false;
        }
    }

    private async Task OnPageSizeChanged(int args)
    {
        pageSize = args;
        page = 1;
        await LoadTransactionsAsync();
    }

    private async Task OnDestinationChanged(string? args)
    {
        selectedDestination = args ?? string.Empty;
        bulkCategory = string.Empty;
        bulkBudget = string.Empty;
        page = 1;
        await RefreshAllAsync();
    }

    private Task OnBulkCategoryChanged(string? args)
    {
        bulkCategory = args ?? string.Empty;
        return Task.CompletedTask;
    }

    private Task OnBulkBudgetChanged(string? args)
    {
        bulkBudget = args ?? string.Empty;
        return Task.CompletedTask;
    }

    private Task OnCategorySelectionChanged(string key, string? value)
    {
        UpdateSelection(key, category: value);
        return Task.CompletedTask;
    }

    private Task OnBudgetSelectionChanged(string key, string? value)
    {
        UpdateSelection(key, budget: value);
        return Task.CompletedTask;
    }

    private async Task ClassifyAsync(UncategorizedTransaction transaction)
    {
        var key = transaction.TransactionJournalId;
        if (!pendingClassifications.Add(key))
        {
            return;
        }

        pageError = null;
        pageSuccess = null;

        try
        {
            var result = await Coordinator.ClassifyForUiAsync(transaction, disposeCts.Token);
            classifications[key] = result;

            var selection = GetSelection(key);
            if (transaction.Category is null && string.IsNullOrWhiteSpace(selection.Category) && !string.IsNullOrWhiteSpace(result.Category))
            {
                selection.Category = result.Category;
            }

            if (transaction.Budget is null && string.IsNullOrWhiteSpace(selection.Budget) && !string.IsNullOrWhiteSpace(result.Budget))
            {
                selection.Budget = result.Budget;
            }

            Snackbar.Add("AI suggestions loaded for the selected transaction.", Severity.Success);
        }
        catch (Exception exception)
        {
            classifications[key] = new ClassificationResult
            {
                Error = exception.Message,
                Status = "failed",
            };

            Snackbar.Add($"Classification failed: {exception.Message}", Severity.Error);
        }
        finally
        {
            pendingClassifications.Remove(key);
        }
    }

    private async Task ApplyAsync(UncategorizedTransaction transaction)
    {
        var key = transaction.TransactionJournalId;
        if (!pendingUpdates.Add(key))
        {
            return;
        }

        pageError = null;
        pageSuccess = null;

        try
        {
            var selection = GetSelection(key);
            var result = await Coordinator.ApplyTransactionUpdateAsync(new ApplyTransactionRequest
            {
                Transaction = transaction,
                Classification = GetClassification(key),
                Selections = selection,
            }, disposeCts.Token);

            transaction.Category = result.Transaction.Category;
            transaction.Budget = result.Transaction.Budget;
            pageSuccess = "Transaction updated successfully.";
            Snackbar.Add("Transaction updated successfully.", Severity.Success);
            await LoadMetadataAsync();
            await LoadTransactionsAsync();
        }
        catch (Exception exception)
        {
            pageError = exception.Message;
            Snackbar.Add($"Update failed: {exception.Message}", Severity.Error);
        }
        finally
        {
            pendingUpdates.Remove(key);
        }
    }

    private async Task PromptBulkApplyAsync()
    {
        if (!CanBulkApply)
        {
            return;
        }

        var confirmed = await DialogService.ShowMessageBoxAsync("Bulk repair", $"Apply the selected values to all matching transactions for {selectedDestination}?", yesText: "Apply changes", cancelText: "Cancel");
        if (confirmed != true)
        {
            return;
        }

        await ApplyBulkAsync();
    }

    private async Task ApplyBulkAsync()
    {
        if (!CanBulkApply)
        {
            return;
        }

        bulkApplyPending = true;
        pageError = null;
        pageSuccess = null;

        try
        {
            var updatedCount = await Coordinator.ApplyDestinationUpdateAsync(selectedDestination, new SelectionValues
            {
                Category = ToNullable(bulkCategory),
                Budget = ToNullable(bulkBudget),
            }, disposeCts.Token);

            pageSuccess = updatedCount == 1
                ? "Updated 1 transaction."
                : $"Updated {updatedCount} transactions.";

            Snackbar.Add(pageSuccess, Severity.Success);

            await RefreshAllAsync();
        }
        catch (Exception exception)
        {
            pageError = exception.Message;
            Snackbar.Add($"Bulk update failed: {exception.Message}", Severity.Error);
        }
        finally
        {
            bulkApplyPending = false;
        }
    }

    private async Task PreviousPageAsync()
    {
        if (page <= 1)
        {
            return;
        }

        page -= 1;
        await LoadTransactionsAsync();
    }

    private async Task NextPageAsync()
    {
        if (!CanMoveNext)
        {
            return;
        }

        page += 1;
        await LoadTransactionsAsync();
    }

    private async Task GoToPageAsync(int targetPage)
    {
        if (targetPage == page)
        {
            return;
        }

        page = targetPage;
        await LoadTransactionsAsync();
    }

    private IEnumerable<int> GetVisiblePages()
    {
        var start = Math.Max(1, page - 2);
        var end = Math.Max(start, Math.Min(totalPages, page + 2));
        return Enumerable.Range(start, end - start + 1);
    }

    private void UpdateSelection(string key, string? category = null, string? budget = null)
    {
        var selection = GetSelection(key);

        if (category is not null)
        {
            selection.Category = ToNullable(category);
        }

        if (budget is not null)
        {
            selection.Budget = ToNullable(budget);
        }
    }

    private SelectionValues GetSelection(string key)
    {
        if (!selections.TryGetValue(key, out var selection))
        {
            selection = new SelectionValues();
            selections[key] = selection;
        }

        return selection;
    }

    private ClassificationResult? GetClassification(string key) => classifications.GetValueOrDefault(key);

    private async Task ShowTransactionDetailsAsync(UncategorizedTransaction transaction)
    {
        var parameters = new DialogParameters<TransactionAiDetailsDialog>
        {
            {
                x => x.Content, new TransactionReviewDialogModel
                {
                    Transaction = transaction,
                    Classification = GetClassification(transaction.TransactionJournalId),
                    Selections = GetSelection(transaction.TransactionJournalId),
                }
            }
        };
        var options = new DialogOptions { Position = DialogPosition.CenterRight, CloseButton = true, MaxWidth = MaxWidth.Medium };
        DialogService.ShowAsync<TransactionAiDetailsDialog>(transaction.DestinationName ?? "Transaction details", parameters, options);
    }

    private bool CanApply(UncategorizedTransaction transaction)
    {
        var selection = GetSelection(transaction.TransactionJournalId);
        var classification = GetClassification(transaction.TransactionJournalId);
        var category = transaction.Category ?? selection.Category ?? classification?.Category;
        var budget = transaction.Budget ?? selection.Budget ?? classification?.Budget;
        return !string.IsNullOrWhiteSpace(category) || !string.IsNullOrWhiteSpace(budget);
    }

    private static string GetTransactionStatus(UncategorizedTransaction transaction)
    {
        if (transaction.Category is null && transaction.Budget is null)
        {
            return "Missing both";
        }

        if (transaction.Category is null || transaction.Budget is null)
        {
            return "Partial";
        }

        return "Ready";
    }

    private static string GetTransactionCss(UncategorizedTransaction transaction)
    {
        if (transaction.Category is null && transaction.Budget is null)
        {
            return "missing-both";
        }

        if (transaction.Category is null || transaction.Budget is null)
        {
            return "partial";
        }

        return "ready";
    }

    private static string GetDisplay(string? value, string fallback) => string.IsNullOrWhiteSpace(value) ? fallback : value;

    private static string FormatAmount(UncategorizedTransaction transaction)
    {
        var amount = GetDisplay(transaction.Amount, "0.00");
        return string.IsNullOrWhiteSpace(transaction.CurrencyCode) ? amount : $"{amount} {transaction.CurrencyCode}";
    }

    private static string? ToNullable(string? value) => string.IsNullOrWhiteSpace(value) ? null : value;

    public async ValueTask DisposeAsync()
    {
        disposeCts.Cancel();
        if (refreshTimer is not null)
        {
            refreshTimer.Dispose();
        }

        if (refreshLoopTask is not null)
        {
            try
            {
                await refreshLoopTask;
            }
            catch (OperationCanceledException)
            {
            }
        }

        disposeCts.Dispose();
    }
}