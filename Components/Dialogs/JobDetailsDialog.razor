@implements IDialogContentComponent<JobRecord>

<FluentStack VerticalGap="16">
    <FluentCard>
        <FluentStack VerticalGap="8">
            <h3>Job summary</h3>
            <FluentStack VerticalGap="6">
                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" Wrap="true" HorizontalGap="12" VerticalGap="4"><span>Status</span><strong>@Content.Status</strong></FluentStack>
                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" Wrap="true" HorizontalGap="12" VerticalGap="4"><span>Destination</span><strong>@(Content.Data.DestinationName ?? "Unknown destination")</strong></FluentStack>
                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" Wrap="true" HorizontalGap="12" VerticalGap="4"><span>Description</span><strong>@(Content.Data.Description ?? "No description")</strong></FluentStack>
                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" Wrap="true" HorizontalGap="12" VerticalGap="4"><span>Category</span><strong>@(Content.Data.Category ?? "Not set")</strong></FluentStack>
                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" Wrap="true" HorizontalGap="12" VerticalGap="4"><span>Budget</span><strong>@(Content.Data.Budget ?? "Not set")</strong></FluentStack>
                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" Wrap="true" HorizontalGap="12" VerticalGap="4"><span>History used</span><strong>@Content.Data.HistoryCount</strong></FluentStack>
            </FluentStack>
        </FluentStack>
    </FluentCard>

    @if (!string.IsNullOrWhiteSpace(Content.Data.ManualUpdate))
    {
        <FluentCard>
            <FluentStack VerticalGap="8">
                <h3>Manual update</h3>
                <div>@Content.Data.ManualUpdate</div>
            </FluentStack>
        </FluentCard>
    }

    @if (!string.IsNullOrWhiteSpace(Content.Data.Error))
    {
        <FluentMessageBar Intent="MessageIntent.Error" Title="Error">@Content.Data.Error</FluentMessageBar>
    }

    @if (!string.IsNullOrWhiteSpace(Content.Data.Prompt))
    {
        <FluentCard>
            <FluentStack VerticalGap="8">
                <h3>Prompt</h3>
                <pre>@Content.Data.Prompt</pre>
            </FluentStack>
        </FluentCard>
    }

    @if (!string.IsNullOrWhiteSpace(Content.Data.Response))
    {
        <FluentCard>
            <FluentStack VerticalGap="8">
                <h3>Model response</h3>
                <pre>@Content.Data.Response</pre>
            </FluentStack>
        </FluentCard>
    }
</FluentStack>

@code {
    [Parameter]
    public JobRecord Content { get; set; } = default!;
}