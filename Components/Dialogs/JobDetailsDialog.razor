<MudDialogContent>
    <MudStack Spacing="4">
        <MudPaper Class="pa-4">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6">Job summary</MudText>
                <MudStack Spacing="1">
                    <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText>Status</MudText><strong>@Content.Status</strong></MudStack>
                    <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText>Destination</MudText><strong>@(Content.Data.DestinationName ?? "Unknown destination")</strong></MudStack>
                    <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText>Description</MudText><strong>@(Content.Data.Description ?? "No description")</strong></MudStack>
                    <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText>Category</MudText><strong>@(Content.Data.Category ?? "Not set")</strong></MudStack>
                    <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText>Budget</MudText><strong>@(Content.Data.Budget ?? "Not set")</strong></MudStack>
                    <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText>History used</MudText><strong>@Content.Data.HistoryCount</strong></MudStack>
                </MudStack>
            </MudStack>
        </MudPaper>

        @if (!string.IsNullOrWhiteSpace(Content.Data.ManualUpdate))
        {
            <MudPaper Class="pa-4">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6">Manual update</MudText>
                    <MudText>@Content.Data.ManualUpdate</MudText>
                </MudStack>
            </MudPaper>
        }

        @if (!string.IsNullOrWhiteSpace(Content.Data.Error))
        {
            <MudAlert Severity="Severity.Error" Title="Error">@Content.Data.Error</MudAlert>
        }

        @if (!string.IsNullOrWhiteSpace(Content.Data.Prompt))
        {
            <MudPaper Class="pa-4">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6">Prompt</MudText>
                    <pre>@Content.Data.Prompt</pre>
                </MudStack>
            </MudPaper>
        }

        @if (!string.IsNullOrWhiteSpace(Content.Data.Response))
        {
            <MudPaper Class="pa-4">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6">Model response</MudText>
                    <pre>@Content.Data.Response</pre>
                </MudStack>
            </MudPaper>
        }
    </MudStack>
</MudDialogContent>
<MudDialogActions>
    <MudButton OnClick="@(() => MudDialog.Close())">Close</MudButton>
</MudDialogActions>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public JobRecord Content { get; set; } = default!;
}
