@implements IDialogContentComponent<TransactionReviewDialogModel>

<FluentStack VerticalGap="16">
    <FluentCard>
        <FluentStack VerticalGap="8">
            <h3>Transaction</h3>
            <FluentStack VerticalGap="6">
                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" Wrap="true" HorizontalGap="12" VerticalGap="4"><span>Destination</span><strong>@(Content.Transaction.DestinationName ?? "Unknown destination")</strong></FluentStack>
                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" Wrap="true" HorizontalGap="12" VerticalGap="4"><span>Description</span><strong>@(Content.Transaction.Description ?? "No description")</strong></FluentStack>
                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" Wrap="true" HorizontalGap="12" VerticalGap="4"><span>Source</span><strong>@(Content.Transaction.SourceName ?? "Unknown source")</strong></FluentStack>
                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" Wrap="true" HorizontalGap="12" VerticalGap="4"><span>Amount</span><strong>@FormatAmount(Content.Transaction)</strong></FluentStack>
                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" Wrap="true" HorizontalGap="12" VerticalGap="4"><span>Current category</span><strong>@(Content.Transaction.Category ?? "Missing")</strong></FluentStack>
                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" Wrap="true" HorizontalGap="12" VerticalGap="4"><span>Current budget</span><strong>@(Content.Transaction.Budget ?? "Missing")</strong></FluentStack>
            </FluentStack>
        </FluentStack>
    </FluentCard>

    <FluentCard>
        <FluentStack VerticalGap="8">
            <h3>Selections and suggestions</h3>
            <FluentStack VerticalGap="6">
                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" Wrap="true" HorizontalGap="12" VerticalGap="4"><span>Selected category</span><strong>@(Content.Selections.Category ?? "None")</strong></FluentStack>
                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" Wrap="true" HorizontalGap="12" VerticalGap="4"><span>Selected budget</span><strong>@(Content.Selections.Budget ?? "None")</strong></FluentStack>
                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" Wrap="true" HorizontalGap="12" VerticalGap="4"><span>AI status</span><strong>@(Content.Classification?.Status ?? "Not classified")</strong></FluentStack>
                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" Wrap="true" HorizontalGap="12" VerticalGap="4"><span>Suggested category</span><strong>@(Content.Classification?.Category ?? "No suggestion")</strong></FluentStack>
                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" Wrap="true" HorizontalGap="12" VerticalGap="4"><span>Suggested budget</span><strong>@(Content.Classification?.Budget ?? "No suggestion")</strong></FluentStack>
                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" Wrap="true" HorizontalGap="12" VerticalGap="4"><span>History used</span><strong>@(Content.Classification?.HistoryCount ?? 0)</strong></FluentStack>
            </FluentStack>
        </FluentStack>
    </FluentCard>

    @if (!string.IsNullOrWhiteSpace(Content.Classification?.Error))
    {
        <FluentMessageBar Intent="MessageIntent.Error" Title="Error">@Content.Classification?.Error</FluentMessageBar>
    }

    @if (!string.IsNullOrWhiteSpace(Content.Classification?.Prompt))
    {
        <FluentCard>
            <FluentStack VerticalGap="8">
                <h3>Prompt</h3>
                <pre>@Content.Classification?.Prompt</pre>
            </FluentStack>
        </FluentCard>
    }

    @if (!string.IsNullOrWhiteSpace(Content.Classification?.Response))
    {
        <FluentCard>
            <FluentStack VerticalGap="8">
                <h3>Model response</h3>
                <pre>@Content.Classification?.Response</pre>
            </FluentStack>
        </FluentCard>
    }
</FluentStack>

@code {
    [Parameter]
    public TransactionReviewDialogModel Content { get; set; } = default!;

    private static string FormatAmount(UncategorizedTransaction transaction)
    {
        var amount = string.IsNullOrWhiteSpace(transaction.Amount) ? "0.00" : transaction.Amount;
        return string.IsNullOrWhiteSpace(transaction.CurrencyCode) ? amount : $"{amount} {transaction.CurrencyCode}";
    }
}