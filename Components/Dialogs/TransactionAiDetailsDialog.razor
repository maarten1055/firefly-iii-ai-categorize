<MudDialogContent>
    <MudStack Spacing="4">
        <MudPaper Class="pa-4">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6">Transaction</MudText>
                <MudStack Spacing="1">
                    <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText>Destination</MudText><strong>@(Content.Transaction.DestinationName ?? "Unknown destination")</strong></MudStack>
                    <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText>Description</MudText><strong>@(Content.Transaction.Description ?? "No description")</strong></MudStack>
                    <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText>Source</MudText><strong>@(Content.Transaction.SourceName ?? "Unknown source")</strong></MudStack>
                    <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText>Amount</MudText><strong>@FormatAmount(Content.Transaction)</strong></MudStack>
                    <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText>Current category</MudText><strong>@(Content.Transaction.Category ?? "Missing")</strong></MudStack>
                    <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText>Current budget</MudText><strong>@(Content.Transaction.Budget ?? "Missing")</strong></MudStack>
                </MudStack>
            </MudStack>
        </MudPaper>

        <MudPaper Class="pa-4">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6">Selections and suggestions</MudText>
                <MudStack Spacing="1">
                    <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText>Selected category</MudText><strong>@(Content.Selections.Category ?? "None")</strong></MudStack>
                    <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText>Selected budget</MudText><strong>@(Content.Selections.Budget ?? "None")</strong></MudStack>
                    <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText>AI status</MudText><strong>@(Content.Classification?.Status ?? "Not classified")</strong></MudStack>
                    <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText>Suggested category</MudText><strong>@(Content.Classification?.Category ?? "No suggestion")</strong></MudStack>
                    <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText>Suggested budget</MudText><strong>@(Content.Classification?.Budget ?? "No suggestion")</strong></MudStack>
                    <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText>History used</MudText><strong>@(Content.Classification?.HistoryCount ?? 0)</strong></MudStack>
                </MudStack>
            </MudStack>
        </MudPaper>

        @if (!string.IsNullOrWhiteSpace(Content.Classification?.Error))
        {
            <MudAlert Severity="Severity.Error" Title="Error">@Content.Classification?.Error</MudAlert>
        }

        @if (!string.IsNullOrWhiteSpace(Content.Classification?.Prompt))
        {
            <MudPaper Class="pa-4">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6">Prompt</MudText>
                    <pre>@Content.Classification?.Prompt</pre>
                </MudStack>
            </MudPaper>
        }

        @if (!string.IsNullOrWhiteSpace(Content.Classification?.Response))
        {
            <MudPaper Class="pa-4">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6">Model response</MudText>
                    <pre>@Content.Classification?.Response</pre>
                </MudStack>
            </MudPaper>
        }
    </MudStack>
</MudDialogContent>
<MudDialogActions>
    <MudButton OnClick="@(() => MudDialog.Close())">Close</MudButton>
</MudDialogActions>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public TransactionReviewDialogModel Content { get; set; } = default!;

    private static string FormatAmount(UncategorizedTransaction transaction)
    {
        var amount = string.IsNullOrWhiteSpace(transaction.Amount) ? "0.00" : transaction.Amount;
        return string.IsNullOrWhiteSpace(transaction.CurrencyCode) ? amount : $"{amount} {transaction.CurrencyCode}";
    }
}
