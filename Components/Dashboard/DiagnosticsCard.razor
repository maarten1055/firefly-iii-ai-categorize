<MudPaper Class="pa-4">
    <MudStack Spacing="3">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <div>
                <MudText Typo="Typo.caption">System check</MudText>
                <MudText Typo="Typo.h5">Provider health</MudText>
            </div>
            @if (IsRunning)
            {
                <MudText><strong>Running checks...</strong></MudText>
            }
        </MudStack>

        @if (!string.IsNullOrWhiteSpace(Error))
        {
            <MudAlert Severity="Severity.Error">Diagnostics failed: @Error</MudAlert>
        }

        @if (Checks.Count == 0 && string.IsNullOrWhiteSpace(Error))
        {
            <MudText>Run a live check against Firefly III and your configured AI provider.</MudText>
        }
        else
        {
            <MudStack Spacing="2">
                @foreach (var check in Checks)
                {
                    <MudAlert Severity="@(check.Ok ? Severity.Success : Severity.Error)">@check.Name: @(check.Ok ? "OK" : "Failed")</MudAlert>
                    @foreach (var pair in check.Details)
                    {
                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText>@pair.Key</MudText>
                            <MudText><strong>@pair.Value</strong></MudText>
                        </MudStack>
                    }
                }
            </MudStack>
        }

        <div>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RefreshRequested">Run diagnostics</MudButton>
        </div>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<DiagnosticCheckItem> Checks { get; set; } = [];

    [Parameter]
    public string? Error { get; set; }

    [Parameter]
    public bool IsRunning { get; set; }

    [Parameter, EditorRequired]
    public EventCallback RefreshRequested { get; set; }
}
