<FluentCard>
    <FluentStack VerticalGap="12">
        <FluentStack Orientation="Orientation.Horizontal" Wrap="true" HorizontalAlignment="HorizontalAlignment.SpaceBetween" HorizontalGap="12" VerticalGap="12">
            <div>
                <small>System check</small>
                <h2>Provider health</h2>
            </div>
            @if (IsRunning)
            {
                <strong>Running checks...</strong>
            }
        </FluentStack>

        @if (!string.IsNullOrWhiteSpace(Error))
        {
            <FluentMessageBar Intent="MessageIntent.Error" Title="Diagnostics failed">@Error</FluentMessageBar>
        }

        @if (Checks.Count == 0 && string.IsNullOrWhiteSpace(Error))
        {
            <p>Run a live check against Firefly III and your configured AI provider.</p>
        }
        else
        {
            <FluentStack VerticalGap="12">
                @foreach (var check in Checks)
                {
                    <FluentCard>
                        <FluentStack VerticalGap="8">
                            <FluentMessageBar Intent="@(check.Ok ? MessageIntent.Success : MessageIntent.Error)" Title="@check.Name">
                                @(check.Ok ? "OK" : "Failed")
                            </FluentMessageBar>
                            @foreach (var pair in check.Details)
                            {
                                <FluentStack Orientation="Orientation.Horizontal" Wrap="true" HorizontalAlignment="HorizontalAlignment.SpaceBetween" HorizontalGap="12" VerticalGap="4">
                                    <span>@pair.Key</span>
                                    <strong>@pair.Value</strong>
                                </FluentStack>
                            }
                        </FluentStack>
                    </FluentCard>
                }
            </FluentStack>
        }

        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="12">
            <FluentButton Appearance="Appearance.Accent" @onclick="RefreshRequested">Run diagnostics</FluentButton>
        </FluentStack>
    </FluentStack>
</FluentCard>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<DiagnosticCheckItem> Checks { get; set; } = [];

    [Parameter]
    public string? Error { get; set; }

    [Parameter]
    public bool IsRunning { get; set; }

    [Parameter, EditorRequired]
    public EventCallback RefreshRequested { get; set; }
}