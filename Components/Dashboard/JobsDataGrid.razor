<MudPaper Class="pa-4">
    <MudStack Spacing="3">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <div>
                <MudText Typo="Typo.caption">Queue activity</MudText>
                <MudText Typo="Typo.h5">Recent jobs</MudText>
            </div>
            <MudText><strong>Live server updates</strong></MudText>
        </MudStack>

        @if (Jobs.Count == 0)
        {
            <MudText>No jobs have been created yet.</MudText>
        }
        else
        {
            <MudTable Items="Jobs" Hover="true" Dense="true" RowsPerPage="8">
                <HeaderContent>
                    <MudTh>Destination</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Description</MudTh>
                    <MudTh>Guess</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Destination">
                        <MudStack Spacing="1">
                            <strong>@GetValue(context.Data.DestinationName, "Unknown destination")</strong>
                            <MudText Typo="Typo.caption">@context.Created.LocalDateTime.ToString("g")</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Status">@GetStatusLabel(context.Status)</MudTd>
                    <MudTd DataLabel="Description">
                        <MudStack Spacing="1">
                            <strong>@GetValue(context.Data.Description, "No description")</strong>
                            <MudText Typo="Typo.caption">ID: @context.Id</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Guess">
                        <MudStack Spacing="1">
                            <strong>Category: @GetValue(context.Data.Category, "Not set")</strong>
                            <MudText Typo="Typo.caption">Budget: @GetValue(context.Data.Budget, "Not set")</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Actions">
                        <MudStack Row="true" Spacing="1">
                            <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="() => ViewDetailsRequested.InvokeAsync(context)">Details</MudButton>
                            @if (CanFillMissing(context))
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                           Disabled="@PendingFillJobIds.Contains(context.Id)"
                                           OnClick="() => FillMissingRequested.InvokeAsync(context.Id)">
                                    @(PendingFillJobIds.Contains(context.Id) ? "Updating..." : $"Fill {GetMissingField(context)}")
                                </MudButton>
                            }
                        </MudStack>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<JobRecord> Jobs { get; set; } = [];

    [Parameter]
    public HashSet<string> PendingFillJobIds { get; set; } = [];

    [Parameter, EditorRequired]
    public EventCallback<string> FillMissingRequested { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<JobRecord> ViewDetailsRequested { get; set; }

    private static string GetStatusLabel(string status) => status switch
    {
        "in_progress" => "In progress",
        "partial" => "Partial",
        "finished" => "Finished",
        "failed" => "Failed",
        _ => "Queued",
    };

    private static bool CanFillMissing(JobRecord job)
    {
        var hasCategory = !string.IsNullOrWhiteSpace(job.Data.Category);
        var hasBudget = !string.IsNullOrWhiteSpace(job.Data.Budget);
        return job.Status == "partial" && hasCategory != hasBudget;
    }

    private static string GetMissingField(JobRecord job) => string.IsNullOrWhiteSpace(job.Data.Category) ? "category" : "budget";

    private static string GetValue(string? value, string fallback) => string.IsNullOrWhiteSpace(value) ? fallback : value;
}
}