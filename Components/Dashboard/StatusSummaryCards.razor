<FluentStack Orientation="Orientation.Horizontal" Wrap="true" HorizontalGap="16" VerticalGap="16">
    <FluentCard style="min-width: 180px;">
        <div>Queued</div>
        <div><strong>@GetStatusCount("queued")</strong></div>
    </FluentCard>
    <FluentCard style="min-width: 180px;">
        <div>In progress</div>
        <div><strong>@GetStatusCount("in_progress")</strong></div>
    </FluentCard>
    <FluentCard style="min-width: 180px;">
        <div>Partial or failed</div>
        <div><strong>@(GetStatusCount("partial") + GetStatusCount("failed"))</strong></div>
    </FluentCard>
    <FluentCard style="min-width: 180px;">
        <div>Finished</div>
        <div><strong>@GetStatusCount("finished")</strong></div>
    </FluentCard>
</FluentStack>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<JobRecord> Jobs { get; set; } = [];

    private int GetStatusCount(string status) => Jobs.Count(job => string.Equals(job.Status, status, StringComparison.Ordinal));
}