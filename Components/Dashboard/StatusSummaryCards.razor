<FluentGrid Spacing="4">
    <FluentGridItem xs="12" sm="6" md="3">
        <FluentCard>
            <small>Queued</small>
            <div style="font-size: 2rem; font-weight: 700; line-height: 1.1;">@GetStatusCount("queued")</div>
        </FluentCard>
    </FluentGridItem>
    <FluentGridItem xs="12" sm="6" md="3">
        <FluentCard>
            <small>In progress</small>
            <div style="font-size: 2rem; font-weight: 700; line-height: 1.1;">@GetStatusCount("in_progress")</div>
        </FluentCard>
    </FluentGridItem>
    <FluentGridItem xs="12" sm="6" md="3">
        <FluentCard>
            <small>Partial or failed</small>
            <div style="font-size: 2rem; font-weight: 700; line-height: 1.1;">@(GetStatusCount("partial") + GetStatusCount("failed"))</div>
        </FluentCard>
    </FluentGridItem>
    <FluentGridItem xs="12" sm="6" md="3">
        <FluentCard>
            <small>Finished</small>
            <div style="font-size: 2rem; font-weight: 700; line-height: 1.1;">@GetStatusCount("finished")</div>
        </FluentCard>
    </FluentGridItem>
</FluentGrid>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<JobRecord> Jobs { get; set; } = [];

    private int GetStatusCount(string status) => Jobs.Count(job => string.Equals(job.Status, status, StringComparison.Ordinal));
}