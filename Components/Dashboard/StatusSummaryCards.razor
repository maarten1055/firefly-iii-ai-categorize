<MudGrid>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Style="border-left: 4px solid #039be5;">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Queued</MudText>
            <MudText Typo="Typo.h4" Style="font-weight:700;line-height:1.1" Color="Color.Info">@GetStatusCount("queued")</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Style="border-left: 4px solid #fb8c00;">
            <MudText Typo="Typo.caption" Color="Color.Secondary">In progress</MudText>
            <MudText Typo="Typo.h4" Style="font-weight:700;line-height:1.1" Color="Color.Warning">@GetStatusCount("in_progress")</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Style="border-left: 4px solid #e53935;">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Partial or failed</MudText>
            <MudText Typo="Typo.h4" Style="font-weight:700;line-height:1.1" Color="Color.Error">@(GetStatusCount("partial") + GetStatusCount("failed"))</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Style="border-left: 4px solid #43a047;">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Finished</MudText>
            <MudText Typo="Typo.h4" Style="font-weight:700;line-height:1.1" Color="Color.Success">@GetStatusCount("finished")</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<JobRecord> Jobs { get; set; } = [];

    private int GetStatusCount(string status) => Jobs.Count(job => string.Equals(job.Status, status, StringComparison.Ordinal));
}
