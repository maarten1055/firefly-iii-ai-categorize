<FluentCard>
    <FluentStack VerticalGap="12">
        <FluentStack Orientation="Orientation.Horizontal" Wrap="true" HorizontalGap="16" VerticalGap="16">
            <FluentStack VerticalGap="6" Width="320px">
                <FluentLabel>Rows per page</FluentLabel>
                <FluentSelect TOption="string" SelectedOption="@CurrentPageSize" SelectedOptionChanged="HandlePageSizeChanged">
                @foreach (var size in PageSizeOptions)
                {
                    <FluentOption Value="@size.ToString()">@size.ToString()</FluentOption>
                }
                </FluentSelect>
            </FluentStack>

            <FluentStack VerticalGap="6" Width="320px">
                <FluentLabel>Destination</FluentLabel>
                <FluentSelect TOption="string" SelectedOption="@SelectedDestination" SelectedOptionChanged="DestinationChanged">
                <FluentOption Value="@string.Empty">All destinations</FluentOption>
                @foreach (var destination in Destinations)
                {
                    <FluentOption Value="@destination">@destination</FluentOption>
                }
                </FluentSelect>
            </FluentStack>
        </FluentStack>
        <p>Page @(Page) of @(PaginationComplete ? TotalPages.ToString() : $"{TotalPages}+")</p>
    </FluentStack>
</FluentCard>

@code {
    [Parameter]
    public int Page { get; set; }

    [Parameter]
    public int PageSize { get; set; }

    [Parameter, EditorRequired]
    public IEnumerable<int> PageSizeOptions { get; set; } = [];

    [Parameter]
    public string SelectedDestination { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public IEnumerable<string> Destinations { get; set; } = [];

    [Parameter]
    public bool PaginationComplete { get; set; }

    [Parameter]
    public int TotalPages { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<int> PageSizeChanged { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<string?> DestinationChanged { get; set; }

    private string CurrentPageSize => PageSize.ToString();

    private Task HandlePageSizeChanged(string? value)
    {
        return int.TryParse(value, out var pageSize)
            ? PageSizeChanged.InvokeAsync(pageSize)
            : Task.CompletedTask;
    }
}