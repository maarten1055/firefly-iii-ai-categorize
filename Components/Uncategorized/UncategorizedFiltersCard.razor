<MudPaper Class="pa-4">
    <MudStack Spacing="3">
        <div>
            <MudText Typo="Typo.caption">Filters</MudText>
            <MudText Typo="Typo.h5">Focus the review list</MudText>
        </div>

        <MudGrid>
            <MudItem xs="12" md="6">
                <MudSelect T="string" Label="Rows per page" Value="@CurrentPageSize" ValueChanged="HandlePageSizeChanged">
                    @foreach (var size in PageSizeOptions)
                    {
                        <MudSelectItem T="string" Value="@size.ToString()">@size.ToString()</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudSelect T="string" Label="Destination" Value="@SelectedDestination" ValueChanged="DestinationChanged">
                    <MudSelectItem T="string" Value="@string.Empty">All destinations</MudSelectItem>
                    @foreach (var destination in Destinations)
                    {
                        <MudSelectItem T="string" Value="@destination">@destination</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        </MudGrid>

        <MudAlert Severity="@(PaginationComplete ? Severity.Success : Severity.Info)">Page @(Page) of @(PaginationComplete ? TotalPages.ToString() : $"{TotalPages}+")</MudAlert>
    </MudStack>
</MudPaper>

@code {
    [Parameter]
    public int Page { get; set; }

    [Parameter]
    public int PageSize { get; set; }

    [Parameter, EditorRequired]
    public IEnumerable<int> PageSizeOptions { get; set; } = [];

    [Parameter]
    public string SelectedDestination { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public IEnumerable<string> Destinations { get; set; } = [];

    [Parameter]
    public bool PaginationComplete { get; set; }

    [Parameter]
    public int TotalPages { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<int> PageSizeChanged { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<string?> DestinationChanged { get; set; }

    private string CurrentPageSize => PageSize.ToString();

    private Task HandlePageSizeChanged(string? value)
    {
        return int.TryParse(value, out var pageSize)
            ? PageSizeChanged.InvokeAsync(pageSize)
            : Task.CompletedTask;
    }
}
