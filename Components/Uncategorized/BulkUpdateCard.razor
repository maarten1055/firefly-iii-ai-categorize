<MudPaper Class="pa-4">
    <MudStack Spacing="3">
        <div>
            <MudText Typo="Typo.caption">Bulk repair</MudText>
            <MudText Typo="Typo.h5">Apply one decision to the current destination</MudText>
        </div>

        <MudText>
            @if (string.IsNullOrWhiteSpace(SelectedDestination))
            {
                <span>Select a destination first to bulk update matching transactions.</span>
            }
            else
            {
                <span>Bulk updates affect empty values for <strong>@SelectedDestination</strong>.</span>
            }
        </MudText>

        <MudGrid>
            <MudItem xs="12" md="6">
                <MudSelect T="string" Label="Bulk category"
                           Value="@BulkCategory"
                           ValueChanged="BulkCategoryChanged"
                           Disabled="@string.IsNullOrWhiteSpace(SelectedDestination)">
                    <MudSelectItem T="string" Value="@string.Empty">Leave unchanged</MudSelectItem>
                    @foreach (var category in Categories)
                    {
                        <MudSelectItem T="string" Value="@category">@category</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudSelect T="string" Label="Bulk budget"
                           Value="@BulkBudget"
                           ValueChanged="BulkBudgetChanged"
                           Disabled="@string.IsNullOrWhiteSpace(SelectedDestination)">
                    <MudSelectItem T="string" Value="@string.Empty">Leave unchanged</MudSelectItem>
                    @foreach (var budget in Budgets)
                    {
                        <MudSelectItem T="string" Value="@budget">@budget</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        </MudGrid>

        <div>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(!CanApply || IsPending)" OnClick="ApplyRequested">
                @(IsPending ? "Applying..." : "Apply to filtered transactions")
            </MudButton>
        </div>
    </MudStack>
</MudPaper>

@code {
    [Parameter]
    public string SelectedDestination { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public IEnumerable<string> Categories { get; set; } = [];

    [Parameter, EditorRequired]
    public IEnumerable<string> Budgets { get; set; } = [];

    [Parameter]
    public string BulkCategory { get; set; } = string.Empty;

    [Parameter]
    public string BulkBudget { get; set; } = string.Empty;

    [Parameter]
    public bool CanApply { get; set; }

    [Parameter]
    public bool IsPending { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<string?> BulkCategoryChanged { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<string?> BulkBudgetChanged { get; set; }

    [Parameter, EditorRequired]
    public EventCallback ApplyRequested { get; set; }
}
