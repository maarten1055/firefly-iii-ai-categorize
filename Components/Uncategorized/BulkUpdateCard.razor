<FluentCard>
    <FluentStack VerticalGap="12">
        <div>
            <small>Bulk repair</small>
            <h2>Apply one decision to the current destination</h2>
        </div>

        <p>
        @if (string.IsNullOrWhiteSpace(SelectedDestination))
        {
            <span>Select a destination first to bulk update matching transactions.</span>
        }
        else
        {
            <span>Bulk updates affect empty values for <strong>@SelectedDestination</strong>.</span>
        }
        </p>

        <FluentGrid Spacing="4">
            <FluentGridItem xs="12" md="6">
                <FluentStack VerticalGap="6">
                    <FluentLabel>Bulk category</FluentLabel>
                    <FluentSelect TOption="string"
                                  SelectedOption="@BulkCategory"
                                  SelectedOptionChanged="BulkCategoryChanged"
                                  Disabled="@string.IsNullOrWhiteSpace(SelectedDestination)">
                    <FluentOption Value="@string.Empty">Leave unchanged</FluentOption>
                    @foreach (var category in Categories)
                    {
                        <FluentOption Value="@category">@category</FluentOption>
                    }
                    </FluentSelect>
                </FluentStack>
            </FluentGridItem>

            <FluentGridItem xs="12" md="6">
                <FluentStack VerticalGap="6">
                    <FluentLabel>Bulk budget</FluentLabel>
                    <FluentSelect TOption="string"
                                  SelectedOption="@BulkBudget"
                                  SelectedOptionChanged="BulkBudgetChanged"
                                  Disabled="@string.IsNullOrWhiteSpace(SelectedDestination)">
                    <FluentOption Value="@string.Empty">Leave unchanged</FluentOption>
                    @foreach (var budget in Budgets)
                    {
                        <FluentOption Value="@budget">@budget</FluentOption>
                    }
                    </FluentSelect>
                </FluentStack>
            </FluentGridItem>
        </FluentGrid>

        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="12">
            <FluentButton Appearance="Appearance.Accent" Disabled="@(!CanApply || IsPending)" @onclick="ApplyRequested">
                @(IsPending ? "Applying..." : "Apply to filtered transactions")
            </FluentButton>
        </FluentStack>
    </FluentStack>
</FluentCard>

@code {
    [Parameter]
    public string SelectedDestination { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public IEnumerable<string> Categories { get; set; } = [];

    [Parameter, EditorRequired]
    public IEnumerable<string> Budgets { get; set; } = [];

    [Parameter]
    public string BulkCategory { get; set; } = string.Empty;

    [Parameter]
    public string BulkBudget { get; set; } = string.Empty;

    [Parameter]
    public bool CanApply { get; set; }

    [Parameter]
    public bool IsPending { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<string?> BulkCategoryChanged { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<string?> BulkBudgetChanged { get; set; }

    [Parameter, EditorRequired]
    public EventCallback ApplyRequested { get; set; }
}