<FluentGrid Spacing="4">
    <FluentGridItem xs="12" sm="6" md="3">
        <FluentCard>
            <small>Transactions in view</small>
            <div style="font-size: 2rem; font-weight: 700; line-height: 1.1;">@Summary.TotalTransactions</div>
        </FluentCard>
    </FluentGridItem>
    <FluentGridItem xs="12" sm="6" md="3">
        <FluentCard>
            <small>Without category</small>
            <div style="font-size: 2rem; font-weight: 700; line-height: 1.1;">@Summary.WithoutCategory</div>
        </FluentCard>
    </FluentGridItem>
    <FluentGridItem xs="12" sm="6" md="3">
        <FluentCard>
            <small>Without budget</small>
            <div style="font-size: 2rem; font-weight: 700; line-height: 1.1;">@Summary.WithoutBudget</div>
        </FluentCard>
    </FluentGridItem>
    <FluentGridItem xs="12" sm="6" md="3">
        <FluentCard>
            <small>Scan status</small>
            <div style="font-size: 1.4rem; font-weight: 700; line-height: 1.1;">@(MetadataComplete && PaginationComplete ? "Complete" : "Updating")</div>
        </FluentCard>
    </FluentGridItem>
</FluentGrid>

@code {
    [Parameter, EditorRequired]
    public MetadataSummary Summary { get; set; } = new();

    [Parameter]
    public bool MetadataComplete { get; set; }

    [Parameter]
    public bool PaginationComplete { get; set; }
}