<MudGrid>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Style="border-left: 4px solid #039be5;">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Transactions in view</MudText>
            <MudText Typo="Typo.h4" Style="font-weight:700;line-height:1.1" Color="Color.Info">@Summary.TotalTransactions</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Style="border-left: 4px solid #fb8c00;">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Without category</MudText>
            <MudText Typo="Typo.h4" Style="font-weight:700;line-height:1.1" Color="Color.Warning">@Summary.WithoutCategory</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Style="border-left: 4px solid #fb8c00;">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Without budget</MudText>
            <MudText Typo="Typo.h4" Style="font-weight:700;line-height:1.1" Color="Color.Warning">@Summary.WithoutBudget</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Style="@($"border-left: 4px solid {(MetadataComplete && PaginationComplete ? "#43a047" : "#039be5")};")">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Scan status</MudText>
            <MudText Typo="Typo.h5" Style="font-weight:700;line-height:1.1" Color="@(MetadataComplete && PaginationComplete ? Color.Success : Color.Info)">
                @(MetadataComplete && PaginationComplete ? "Complete" : "Updating")
            </MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    [Parameter, EditorRequired]
    public MetadataSummary Summary { get; set; } = new();

    [Parameter]
    public bool MetadataComplete { get; set; }

    [Parameter]
    public bool PaginationComplete { get; set; }
}
