<FluentStack Orientation="Orientation.Horizontal" Wrap="true" HorizontalGap="16" VerticalGap="16">
    <FluentCard style="min-width: 180px;">
        <div>Transactions in view</div>
        <div><strong>@Summary.TotalTransactions</strong></div>
    </FluentCard>
    <FluentCard style="min-width: 180px;">
        <div>Without category</div>
        <div><strong>@Summary.WithoutCategory</strong></div>
    </FluentCard>
    <FluentCard style="min-width: 180px;">
        <div>Without budget</div>
        <div><strong>@Summary.WithoutBudget</strong></div>
    </FluentCard>
    <FluentCard style="min-width: 180px;">
        <div>Scan status</div>
        <div><strong>@(MetadataComplete && PaginationComplete ? "Complete" : "Updating")</strong></div>
    </FluentCard>
</FluentStack>

@code {
    [Parameter, EditorRequired]
    public MetadataSummary Summary { get; set; } = new();

    [Parameter]
    public bool MetadataComplete { get; set; }

    [Parameter]
    public bool PaginationComplete { get; set; }
}