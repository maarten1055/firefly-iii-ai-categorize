@inherits LayoutComponentBase

<FluentDesignTheme @bind-Mode="themeMode"
                   @bind-OfficeColor="themeColor"
                   StorageName="firefly-theme" />
<FluentToastProvider MaxToastCount="5" Timeout="5000" />
<FluentDialogProvider />

    <FluentStack VerticalGap="24">
        <FluentCard>
            <FluentGrid Spacing="4">
                <FluentGridItem xs="12" lg="8">
                    <FluentStack VerticalGap="10">
                        <FluentStack VerticalGap="4">
                            <small>Blazor server console</small>
                            <strong style="font-size: 1.8rem; line-height: 1.1;">Firefly III AI Categorizer</strong>
                        </FluentStack>

                        <FluentStack Orientation="Orientation.Horizontal" Wrap="true" HorizontalGap="12" VerticalGap="12">
                            <FluentButton Appearance="Appearance.Accent" Href="/">Dashboard</FluentButton>
                            <FluentButton Appearance="Appearance.Outline" Href="/uncategorized">Uncategorized</FluentButton>
                        </FluentStack>
                    </FluentStack>
                </FluentGridItem>

                <FluentGridItem xs="12" lg="4">
                    <FluentStack VerticalGap="8" HorizontalAlignment="HorizontalAlignment.End">
                        <small>Theme</small>
                        <ThemeSwitcher @bind-Mode="themeMode" @bind-OfficeColor="themeColor" />
                    </FluentStack>
                </FluentGridItem>
            </FluentGrid>
        </FluentCard>

        <main>
            @Body
        </main>

        <footer>
            <small>Server-rendered with Blazor and Fluent UI.</small>
        </footer>
    </FluentStack>

@code {
    private DesignThemeModes themeMode = DesignThemeModes.System;
    private OfficeColor? themeColor = OfficeColor.Excel;
}