<MudTooltip Text="@(IsDarkMode ? "Switch to light mode" : "Switch to dark mode")">
    <MudIconButton Icon="@(IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                   Color="Color.Inherit"
                   OnClick="Toggle" />
</MudTooltip>

@code {
    [Parameter]
    public bool IsDarkMode { get; set; }

    [Parameter]
    public EventCallback<bool> IsDarkModeChanged { get; set; }

    private Task Toggle() => IsDarkModeChanged.InvokeAsync(!IsDarkMode);
}
