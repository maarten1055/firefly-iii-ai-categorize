@page "/"
@implements IDisposable
@inject JobStore JobStore
@inject FireflyService FireflyService
@inject AiClassifierService AiClassifierService
@inject CategorizationCoordinator Coordinator
@inject IDialogService DialogService
@inject IToastService ToastService

<PageTitle>Dashboard</PageTitle>

<section class="page-grid">
    <FluentCard Class="hero-card">
        <div class="hero-kicker">Operations dashboard</div>
        <h1>Keep an eye on automation without leaving Firefly.</h1>
        <p class="hero-copy">
            Watch webhook jobs, inspect AI output, and repair partial categorizations from one server-side console.
        </p>
        <div class="hero-actions">
            <FluentButton Appearance="Appearance.Accent" @onclick="RunDiagnosticsAsync">Run diagnostics</FluentButton>
            <a href="/uncategorized" class="app-link-button">Review uncategorized transactions</a>
        </div>
    </FluentCard>

    <StatusSummaryCards Jobs="jobs" />

    <DiagnosticsCard Checks="diagnosticChecks"
                     Error="diagnosticsError"
                     IsRunning="diagnosticsRunning"
                     RefreshRequested="RunDiagnosticsAsync" />

    <JobsDataGrid Jobs="jobs"
                  PendingFillJobIds="pendingFillJobIds"
                  FillMissingRequested="PromptFillMissingAsync"
                  ViewDetailsRequested="ShowJobDetailsAsync" />
</section>

@code {
    private readonly CancellationTokenSource disposeCts = new();
    private readonly HashSet<string> pendingFillJobIds = [];
    private List<JobRecord> jobs = [];
    private List<DiagnosticCheckItem> diagnosticChecks = [];
    private bool diagnosticsRunning;
    private string? diagnosticsError;

    protected override void OnInitialized()
    {
        jobs = JobStore.GetJobsSnapshot().ToList();
        JobStore.Changed += HandleJobsChanged;
    }

    private void HandleJobsChanged()
    {
        _ = InvokeAsync(() =>
        {
            jobs = JobStore.GetJobsSnapshot().ToList();
            StateHasChanged();
        });
    }

    private async Task RunDiagnosticsAsync()
    {
        diagnosticsRunning = true;
        diagnosticsError = null;

        try
        {
            diagnosticChecks =
            [
                await BuildDiagnosticCheckAsync("Firefly III", () => FireflyService.DiagnoseAsync(disposeCts.Token)),
                await BuildDiagnosticCheckAsync("AI provider", () => AiClassifierService.DiagnoseAsync(disposeCts.Token)),
            ];

            if (diagnosticChecks.All(check => check.Ok))
            {
                ToastService.ShowSuccess("Diagnostics completed successfully.");
            }
            else
            {
                ToastService.ShowWarning("Diagnostics completed with failures.");
            }
        }
        catch (Exception exception)
        {
            diagnosticsError = exception.Message;
            ToastService.ShowError($"Diagnostics failed: {exception.Message}");
        }
        finally
        {
            diagnosticsRunning = false;
        }
    }

    private async Task<DiagnosticCheckItem> BuildDiagnosticCheckAsync(string name, Func<Task<object>> action)
    {
        try
        {
            var result = await action();
            return new DiagnosticCheckItem
            {
                Name = name,
                Ok = true,
                Details = Describe(result),
            };
        }
        catch (Exception exception)
        {
            return new DiagnosticCheckItem
            {
                Name = name,
                Ok = false,
                Details = new Dictionary<string, string>(StringComparer.Ordinal)
                {
                    ["Error"] = exception.Message,
                },
            };
        }
    }

    private async Task PromptFillMissingAsync(string jobId)
    {
        var dialog = await DialogService.ShowConfirmationAsync("Fill the remaining category or budget for this job?", "Fill missing value", "Cancel", "Repair partial job");
        var result = await dialog.Result;
        if (result.Cancelled)
        {
            return;
        }

        await FillMissingAsync(jobId);
    }

    private async Task FillMissingAsync(string jobId)
    {
        if (!pendingFillJobIds.Add(jobId))
        {
            return;
        }

        try
        {
            await Coordinator.FillMissingJobValueAsync(jobId, disposeCts.Token);
            ToastService.ShowSuccess("Missing value filled for the selected job.");
        }
        catch (Exception exception)
        {
            ToastService.ShowError($"Could not fill missing value: {exception.Message}");
            throw;
        }
        finally
        {
            pendingFillJobIds.Remove(jobId);
        }
    }

    private async Task ShowJobDetailsAsync(JobRecord job)
    {
        await DialogService.ShowPanelAsync<JobDetailsDialog>(job, new DialogParameters
        {
            Title = job.Data.DestinationName ?? "Job details",
            Width = "720px",
            Alignment = HorizontalAlignment.Right,
            Modal = false,
            ShowDismiss = true,
        });
    }

    private static Dictionary<string, string> Describe(object value)
    {
        return value.GetType()
            .GetProperties(BindingFlags.Instance | BindingFlags.Public)
            .ToDictionary(
                property => property.Name,
                property => Convert.ToString(property.GetValue(value), System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty,
                StringComparer.Ordinal);
    }

    public void Dispose()
    {
        JobStore.Changed -= HandleJobsChanged;
        disposeCts.Cancel();
        disposeCts.Dispose();
    }
}