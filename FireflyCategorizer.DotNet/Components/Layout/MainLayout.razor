@inherits LayoutComponentBase

<FluentDesignTheme @bind-Mode="themeMode"
                   @bind-OfficeColor="themeColor"
                   StorageName="firefly-theme" />
<FluentToastProvider MaxToastCount="5" Timeout="5000" />
<FluentDialogProvider />

<div class="shell">
    <header class="shell-header">
        <div>
            <div class="shell-kicker">Blazor server console</div>
            <div class="shell-title">Firefly III AI Categorizer</div>
        </div>
        <div class="shell-header-actions">
            <nav class="shell-nav">
                <NavLink href="/" Match="NavLinkMatch.All" class="shell-nav-link">Dashboard</NavLink>
                <NavLink href="/uncategorized" class="shell-nav-link">Uncategorized</NavLink>
            </nav>
            <ThemeSwitcher @bind-Mode="themeMode" @bind-OfficeColor="themeColor" />
        </div>
    </header>

    <main class="shell-content">
        @Body
    </main>
    <footer class="shell-footer">
        <span>Server-rendered with Blazor and Fluent UI.</span>
    </footer>
</div>

@code {
    private DesignThemeModes themeMode = DesignThemeModes.System;
    private OfficeColor? themeColor = OfficeColor.Excel;
}