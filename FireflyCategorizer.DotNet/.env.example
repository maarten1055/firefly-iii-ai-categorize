# Copy this file to .env and fill in your own values.

FIREFLY_URL=https://firefly.example.com
FIREFLY_PERSONAL_TOKEN=eyabc123...

# Enable exactly one AI provider, or set both and Mistral will be preferred.
MISTRAL_API_KEY=mistral-abc123...
# OPENAI_API_KEY=sk-abc123...

ENABLE_UI=true
FIREFLY_TAG=AI categorized

# Optional model overrides
MISTRAL_MODEL=mistral-small-latest
OPENAI_MODEL=gpt-4o-mini

# Optional local bind address
ASPNETCORE_URLS=http://127.0.0.1:5087